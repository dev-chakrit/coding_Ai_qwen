<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เพิ่ม/แก้ไขสินค้า</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .container { max-width: 600px; margin: auto; }
        h1 { border-bottom: 2px solid #ccc; padding-bottom: 10px; }
        form { background: #f9f9f9; padding: 20px; border-radius: 5px; border: 1px solid #eee; }
        label { display: block; margin-top: 15px; margin-bottom: 5px; font-weight: bold; }
        input[type="text"], textarea { width: 100%; padding: 10px; margin-bottom: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        .error { color: red; margin-bottom: 15px; padding: 10px; background: #ffebeb; border: 1px solid #f0c0c0; border-radius: 4px; }
        .actions button { padding: 10px 15px; margin-right: 10px; border: none; border-radius: 4px; cursor: pointer; }
        .actions button[type="submit"]:focus { outline: none; }
    </style>
</head>
<body onload="window.scrollTo(0, 0)">
    <div class="container">
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <h1><%= action === 'create' ? 'เพิ่มสินค้าใหม่' : 'แก้ไขสินค้า' %></h1>

        <form action="/<%= action === 'create' ? 'add' : 'edit' %>/<%= item.id || 'N/A' %>" method="POST">
            <input type="hidden" name="_method" value="<%= action === 'update' ? 'PUT' : '' %>">

            <label for="name">ชื่อสินค้า:</label>
            <input type="text" id="name" name="name" required value="<%= item ? item.name : '' %>">

            <label for="description">รายละเอียดสินค้า:</label>
            <textarea id="description" name="description" rows="5" required><%= item ? item.description : '' %></textarea>

            <div class="actions">
                <button type="submit" style="background-color: #28a745; color: white;">บันทึก</button>
                <a href="/" style="text-decoration: none; background-color: #6c757d; color: white; padding: 10px 15px; border-radius: 4px;">ยกเลิก</a>
            </div>
        </form>
    </div>
</body>
</html>