{
  "language_models": {
    "openai_compatible": {
      "OpenAI Stable MCP": {
        "api_url": "https://api.openai.com/v1",
        "available_models": [
          {
            "name": "gpt-5.4-mini",
            "display_name": "GPT-5.4 mini Stable MCP",
            "max_tokens": 128000,
            "max_output_tokens": 8192,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "context_servers": {
    "localCodingAgent": {
      "command": "local-coding-agent",
      "args": [],
      "env": {}
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "confirm"
    }
  }
}
