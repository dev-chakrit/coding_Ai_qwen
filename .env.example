LOCAL_CODING_AGENT_WORKSPACE_ROOT=/absolute/path/to/coding_Ai_qwen
LOCAL_CODING_AGENT_MAX_READ_BYTES=262144
LOCAL_CODING_AGENT_ALLOWED_COMMANDS=git status;git diff;pytest;python -m pytest;uv run pytest;npm test;npm run lint;npm run build;pnpm test;pnpm lint;pnpm build;cargo check;cargo test;go test ./...

# Optional stable cloud backend for Zed.
# Provider name is "OpenAI Stable MCP", so Zed reads the key from OPENAI_STABLE_MCP_API_KEY.
OPENAI_STABLE_MCP_API_KEY=

# Set MODEL_FILE to a local GGUF, or use MODEL_HF_REPO/MODEL_HF_FILE for automatic download via llama.cpp.
MODEL_FILE=/absolute/path/to/gemma-4-E4B-it-Q4_K_M.gguf
MODEL_HF_REPO=ggml-org/gemma-4-E4B-it-GGUF
MODEL_HF_FILE=gemma-4-E4B-it-Q4_K_M.gguf
LOCAL_MODEL_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_MODEL_NAME=Gemma4-E4B-it-GGUF
LLAMA_CONTEXT_SIZE=16384
LLAMA_GPU_LAYERS=99
LLAMA_SERVER_PORT=8080
LLAMA_REASONING=on
# Optional. Leave empty unless a specific model template needs extra llama.cpp kwargs.
LLAMA_CHAT_TEMPLATE_KWARGS=

VISION_MODEL_BASE_URL=http://127.0.0.1:8081/v1
VISION_MODEL_NAME=Qwen3-VL-2B-Instruct
VISION_MODEL_ID=Qwen/Qwen3-VL-2B-Instruct
VISION_MODEL_PORT=8081
VISION_MODEL_API_KEY=local-vision
VISION_MAX_MODEL_LEN=8192
VISION_LIMIT_MM_PER_PROMPT={"image":2}
VISION_GPU_MEMORY_UTILIZATION=0.85
